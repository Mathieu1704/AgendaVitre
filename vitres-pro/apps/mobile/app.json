{
  "expo": {
    "name": "LVM Agenda",
    "slug": "LVM-Agenda",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/LVM_icone_ios.png",
    "scheme": "lvm-agenda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/LVM_LOGO_Colors-01.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.lvmagenda.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "be.lvmagenda.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/LVM_LOGO_Colors-01.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/LVM_LOGO_Colors-01.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "privacyManifests": {
              "NSPrivacyTracking": false,
              "NSPrivacyTrackingDomains": [],
              "NSPrivacyCollectedDataTypes": [],
              "NSPrivacyAccessedAPITypes": [
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
                  "NSPrivacyAccessedAPITypeReasons": [
                    "CA92.1"
                  ]
                },
                {
                  "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
                  "NSPrivacyAccessedAPITypeReasons": [
                    "C617.1"
                  ]
                }
              ]
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0e90d5a7-2d9a-46b5-88ec-c0ef3f8f061f"
      }
    }
  }
}
